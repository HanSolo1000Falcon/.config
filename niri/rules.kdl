layer-rule {
  match namespace="^noctalia-wallpaper*"
  place-within-backdrop true
}

window-rule {
  clip-to-geometry true
}

window-rule {
  match app-id="gorilla-mod-manager"
  match app-id="gorilla-cheats"
  open-floating true
}

window-rule {
  match app-id="zed"
  open-maximized true
  open-fullscreen false
}

window-rule {
  match app-id="kitty"
  match app-id="ghostty"
  opacity 0.7
}
