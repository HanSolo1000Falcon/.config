layer-rule {
  match namespace="^noctalia-wallpaper*"
  place-within-backdrop true
}

window-rule {
  geometry-corner-radius 7
  clip-to-geometry true
}

window-rule {
  match app-id="gorilla-mod-manager"
  open-floating true
}

window-rule {
  match app-id="zed"
  open-maximized true
  open-fullscreen false
}

window-rule {
  match app-id="kitty"
  match app-id="vesktop"
  match app-id="equibop"
  match app-id="Spotify"
  opacity 0.9
}
