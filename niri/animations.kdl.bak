animations {
  on
  slowdown 1.2

  window-open {
    duration-ms 200
    curve "linear"
    custom-shader r"
    vec4 expanding_square(vec3 coords_geo, vec3 size_geo) {
      vec3 coords_tex = niri_geo_to_tex * coords_geo;
      vec4 color = texture2D(niri_tex, coords_tex.st);
      vec2 coords = (coords_geo.xy - vec2(0.5, 0.5)) * size_geo.xy * 2.0;
      coords = coords / length(size_geo.xy);
      float p = niri_clamped_progress;
      float d = max(abs(coords.x), abs(coords.y));
      if (p <= d)
        color = vec4(0.0);
      return color;
    }
    vec4 open_color(vec3 coords_geo, vec3 size_geo) {
      return expanding_square(coords_geo, size_geo);
    }
    "
  }

  window-close {
    duration-ms 175
    curve "linear"
    custom-shader r"
    vec4 shrinking_square(vec3 coords_geo, vec3 size_geo) {
      vec3 coords_tex = niri_geo_to_tex * coords_geo;
      vec4 color = texture2D(niri_tex, coords_tex.st);
      vec2 coords = (coords_geo.xy - vec2(0.5, 0.5)) * size_geo.xy * 2.0;
      coords = coords / length(size_geo.xy);
      float p_close = 1.0 - niri_clamped_progress;
      float d = max(abs(coords.x), abs(coords.y));
      if (p_close <= d)
        color = vec4(0.0);
      return color;
    }
    vec4 close_color(vec3 coords_geo, vec3 size_geo) {
      return shrinking_square(coords_geo, size_geo);
    }
    "
  }

  window-resize {
  }
}
